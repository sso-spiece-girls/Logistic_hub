# === Logistic Hub — Variabili d'ambiente ===

# (Obbligatoria) Chiave segreta per sessioni Flask
SECRET_KEY=una-stringa-casuale-molto-lunga

# (Obbligatoria su Railway) URL del database PostgreSQL
# Railway la imposta automaticamente. In locale lascia SQLite.
DATABASE_URL=

# (Opzionale) Password per l'utente admin
# Se non impostata, viene generata casualmente e stampata nei log
ADMIN_PASSWORD=mia-password-sicura

# (Opzionale) Email admin
ADMIN_EMAIL=admin@logistichub.local

# (Opzionale) Porta server (default: 5000)
PORT=5000

# (Opzionale) Percorso upload file
UPLOAD_FOLDER=data/docs

# (Opzionale) Percorso backup
BACKUP_FOLDER=data/backup

# (Opzionale) Debug mode (0 o 1)
FLASK_DEBUG=0
